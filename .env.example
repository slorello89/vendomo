# Copy to .env to override defaults. All values are optional.

# Number of vending machines to seed on first boot.
# Default is 1000. Bump to 100000 for the performance/optimization exercise.
SEED_COUNT=1000

# How many simulated revenue events per second the worker pushes to the stream.
REVENUE_EVENTS_PER_SEC=8

# API key for natural-language features (Anthropic Claude). Leave blank if unused.
ANTHROPIC_API_KEY=
# Model for extraction-style calls; a small/fast model is plenty.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
